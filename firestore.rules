import { useParams, Link, Navigate } from 'react-router-dom';
import { motion } from 'motion/react';
import { ArrowLeft, CheckCircle2, Quote, TrendingUp, ShieldCheck, Zap, ArrowRight } from 'lucide-react';
import { caseStudies } from '../data/caseStudies';

export default function CaseStudyDetail() {
  const { id } = useParams<{ id: string }>();
  const study = caseStudies.find(s => s.id === id);

  if (!study) {
    return <Navigate to="/case-studies" replace />;
  }

  return (
    <div className="bg-background min-h-screen bg-grain">
      {/* Hero Section */}
      <div className="relative h-[80vh] min-h-[600px] overflow-hidden">
        <img 
          src={study.image} 
          alt={study.title} 
          className="w-full h-full object-cover" 
          referrerPolicy="no-referrer"
        />
        <div className="absolute inset-0 bg-gradient-to-t from-primary via-primary/40 to-transparent" />
        
        <div className="absolute inset-0 flex items-end pb-24">
          <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
            <motion.div
              initial={{ opacity: 0, y: 30 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ duration: 0.8 }}
            >
              <Link 
                to="/case-studies" 
                className="inline-flex items-center text-[10px] font-bold text-accent uppercase tracking-[0.3em] mb-8 hover:text-white transition-colors group"
              >
                <ArrowLeft className="mr-3 w-4 h-4 group-hover:-translate-x-2 transition-transform" /> Back to Case Studies
              </Link>
              <span className="block px-4 py-1.5 bg-accent/20 text-accent text-[10px] font-bold tracking-[0.3em] uppercase rounded-full mb-8 border border-accent/30 w-fit">
                {study.category}
              </span>
              <h1 className="text-4xl md:text-7xl font-serif font-bold text-white mb-8 leading-tight max-w-4xl">
                {study.title}
              </h1>
              
              <div className="flex flex-wrap gap-12 text-white/80">
                <div>
                  <div className="text-[10px] font-bold uppercase tracking-widest text-accent mb-2">Client</div>
                  <div className="text-lg font-light">{study.client}</div>
                </div>
                <div>
                  <div className="text-[10px] font-bold uppercase tracking-widest text-accent mb-2">Industry</div>
                  <div className="text-lg font-light">{study.industry}</div>
                </div>
              </div>
            </motion.div>
          </div>
        </div>
      </div>

      {/* Main Content */}
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-24">
          {/* Detailed Content */}
          <div className="lg:col-span-2 space-y-24">
            <section>
              <h2 className="text-3xl font-serif font-bold text-primary mb-8 flex items-center">
                <span className="w-12 h-12 rounded-2xl bg-paper flex items-center justify-center text-accent mr-6 flex-shrink-0 shadow-sm">
                  <Zap className="w-6 h-6" />
                </span>
                The Challenge
              </h2>
              <p className="text-xl text-gray-600 font-light leading-relaxed italic">
                {study.challenge}
              </p>
            </section>

            <section>
              <h2 className="text-3xl font-serif font-bold text-primary mb-8 flex items-center">
                <span className="w-12 h-12 rounded-2xl bg-paper flex items-center justify-center text-accent mr-6 flex-shrink-0 shadow-sm">
                  <ShieldCheck className="w-6 h-6" />
                </span>
                Our Strategic Solution
              </h2>
              <p className="text-xl text-gray-600 font-light leading-relaxed">
                {study.solution}
              </p>
            </section>

            <section className="bg-white p-16 rounded-[3rem] shadow-sm border border-accent/5">
              <h2 className="text-3xl font-serif font-bold text-primary mb-12 flex items-center">
                <span className="w-12 h-12 rounded-2xl bg-paper flex items-center justify-center text-accent mr-6 flex-shrink-0 shadow-sm">
                  <TrendingUp className="w-6 h-6" />
                </span>
                Measurable Results
              </h2>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
                {study.results.map((result, idx) => (
                  <motion.div 
                    key={idx}
                    initial={{ opacity: 0, x: -20 }}
                    whileInView={{ opacity: 1, x: 0 }}
                    viewport={{ once: true }}
                    transition={{ delay: idx * 0.1 }}
                    className="flex items-start p-6 rounded-2xl bg-paper border border-accent/5"
                  >
                    <CheckCircle2 className="w-6 h-6 text-accent mr-4 flex-shrink-0 mt-1" />
                    <span className="text-gray-700 font-light leading-relaxed">{result}</span>
                  </motion.div>
                ))}
              </div>
            </section>

            {study.testimonial && (
              <section className="relative py-16 px-12 bg-primary text-white rounded-[3rem] overflow-hidden">
                <Quote className="absolute top-12 left-12 w-24 h-24 text-white/5 pointer-events-none" />
                <div className="relative z-10 text-center">
                  <p className="text-2xl md:text-3xl font-serif italic font-light mb-12 leading-relaxed">
                    "{study.testimonial.quote}"
                  </p>
                  <div>
                    <div className="text-accent font-bold text-[11px] uppercase tracking-[0.3em] mb-2">{study.testimonial.author}</div>
                    <div className="text-white/60 text-sm font-light uppercase tracking-widest">{study.testimonial.position}</div>
                  </div>
                </div>
              </section>
            )}
          </div>

          {/* Sidebar Stats */}
          <div className="lg:col-span-1">
            <div className="sticky top-32 space-y-12">
              <div className="bg-white p-12 rounded-[3rem] shadow-sm border border-accent/5">
                <h3 className="text-xl font-serif font-bold text-primary mb-10 text-center uppercase tracking-widest">Key Performance Indicators</h3>
                <div className="space-y-10">
                  {study.stats.map((stat, idx) => (
                    <div key={idx} className="text-center group">
                      <div className="text-5xl font-serif font-bold text-primary mb-3 group-hover:text-accent transition-colors duration-300">{stat.value}</div>
                      <div className="text-[11px] text-accent font-bold uppercase tracking-[0.3em]">{stat.label}</div>
                    </div>
                  ))}
                </div>
              </div>

              <div className="bg-accent p-12 rounded-[3rem] text-white shadow-xl shadow-accent/20">
                <h3 className="text-2xl font-serif font-bold mb-6 leading-tight">Need similar results?</h3>
                <p className="text-white/80 font-light mb-10 leading-relaxed">
                  Let's discuss how our expertise can help your organization achieve its financial goals.
                </p>
                <Link 
                  to="/contact" 
                  className="w-full bg-white text-primary px-8 py-5 rounded-xl font-bold text-[11px] uppercase tracking-[0.3em] hover:bg-white/90 transition-all flex items-center justify-center shadow-lg"
                >
                  Contact Us Now <ArrowRight className="ml-3 w-4 h-4" />
                </Link>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
